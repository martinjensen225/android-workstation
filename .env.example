# Required identity settings
GIT_USER_NAME="REPLACE_ME"
GIT_USER_EMAIL="REPLACE_ME"

# Required only when ENABLE_CODE_SERVER=true
CODE_SERVER_PASSWORD="REPLACE_ME"

# Leave empty for an unencrypted key, or set a passphrase for stronger protection.
# Empty is the only fully non-interactive SSH-key path.
SSH_KEY_PASSPHRASE=""
DEBIAN_SSH_KEY_PASSPHRASE="$SSH_KEY_PASSPHRASE"

# Core workstation settings
TERMUX_EDITOR="nano"
PRIMARY_GITHUB_HOST="github.com"

WORKSPACE_ROOT="$HOME/code"
WORK_REPO_ROOT="$WORKSPACE_ROOT/work"
PERSONAL_REPO_ROOT="$WORKSPACE_ROOT/personal"
SCRATCH_REPO_ROOT="$WORKSPACE_ROOT/scratch"

CODE_SERVER_BIND_HOST="127.0.0.1"
CODE_SERVER_PORT="8080"

# Obsidian options:
# - clone: clone an existing vault repo after GitHub SSH is working
# - init:  create a new local Git repo in shared storage
# - skip:  prepare shared storage only and leave the vault for later
OBSIDIAN_BASE_DIR="$HOME/storage/shared/Documents/Obsidian"
OBSIDIAN_VAULT_NAME="work-vault"
OBSIDIAN_VAULT_MODE="clone"
OBSIDIAN_VAULT_REPO_URL="git@github.com:REPLACE_ME/REPLACE_ME.git"

# Standard editor workflow defaults to Debian in proot-distro with VS Code tunnel.
# Enable code-server only if you want the local fallback editor as well.
ENABLE_CODE_SERVER="false"
ENABLE_NEOVIM="true"
ENABLE_GITHUB_COPILOT_VIM="false"
ENABLE_CODEX_TERMUX="false"
ENABLE_DEBIAN_WORKFLOW="true"
ENABLE_VSCODE_TUNNEL="true"
ENABLE_AZURE_CLI_DEBIAN="false"

# Optional Debian userspace identity
DEBIAN_DISTRO="debian"
DEBIAN_GIT_USER_NAME="$GIT_USER_NAME"
DEBIAN_GIT_USER_EMAIL="$GIT_USER_EMAIL"

# Optional overrides
BACKUP_EXPORT_ROOT="$HOME/storage/shared/Documents/Backups/galaxy-dex-workstation"

# Leave blank to use manifest/repos.local.json next to this bundle.
REPO_MANIFEST_PATH=""
